      "version": "0.1.0",
      "license": "MIT",
      "category": "creative",
      "keywords": ["midi", "music", "composition"]
    },
    {
      "name": "fcp-terraform",
      "source": { "source": "github", "repo": "aetherwing-io/fcp-terraform" },
      "description": "Generate Terraform HCL through resource declarations",
      "version": "0.1.2",
      "license": "MIT",
      "category": "devops",
      "keywords": ["terraform", "hcl", "infrastructure"]
    }
