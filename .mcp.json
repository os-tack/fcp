{
  "mcpServers": {
    "terraform": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run-terraform.sh"]
    },
    "drawio": {
      "command": "npx",
      "args": ["-y", "@aetherwing/fcp-drawio"]
    },
    "midi": {
      "command": "uvx",
      "args": ["--refresh-package", "fcp-midi", "--python", "3.13", "fcp-midi"]
    },
    "sheets": {
      "command": "uvx",
      "args": ["--refresh-package", "fcp-sheets", "--python", "3.13", "fcp-sheets"]
    },
    "slides": {
      "command": "uvx",
      "args": ["--refresh-package", "fcp-slides", "--python", "3.13", "fcp-slides"]
    },
    "rust": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run-rust.sh"]
    },
    "regex": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run-regex.sh"]
    }
  }
}
